def analyze(percentages):
  # Write code below 💖
    net_change=0
    average=0
    dip=0
    years=len(percentages)
    net_change=(percentages[len(percentages)-1] - percentages[0])/(years-1)
    first_av=(percentages[0]+percentages[1]+percentages[2])/3
    last_av=(percentages[len(percentages)-1]+percentages[len(percentages)-2]+percentages[len(percentages)-3])/3
    for i in range(1,len(percentages)):
        if percentages[i]<percentages[i-1]:
            dip+=1
    return round(net_change,4) ,"improving" if last_av > first_av else "stagnating" if last_av == first_av else "declining",dip
