  def cuddly_kittens(kittens, limit):
    from collections import deque

    max_d = deque()  # stores max values
    min_d = deque()  # stores min values

    left = 0
    result = 0

    for right in range(len(kittens)):
        # maintain max deque (decreasing)
        while max_d and kittens[right] > max_d[-1]:
            max_d.pop()
        max_d.append(kittens[right])

        # maintain min deque (increasing)
        while min_d and kittens[right] < min_d[-1]:
            min_d.pop()
        min_d.append(kittens[right])

        # shrink window if invalid
        while max_d[0] - min_d[0] > limit:
            if kittens[left] == max_d[0]:
                max_d.popleft()
            if kittens[left] == min_d[0]:
                min_d.popleft()
            left += 1

        result = max(result, right - left + 1)

    return result



