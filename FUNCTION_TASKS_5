# Bonus:
# For all the super fans, try and add more attributes
# to the Pokemon class definition,
# like level, region, height, or weight.




# Write code below 💖
class pokemon:
  def __init__(self,entry,name,types,description,is_caught,level,region):
    self.entry=entry
    self.name=name
    self.types=types
    self.description=description
    self.is_caught=is_caught
    self.region=region
    self.level=level

  def speak(self):
    print(self.name + self.name)
  def display_details(self):
    print("Entry Number :",self.entry,"\n Name :"+self.name+"\n Type:"+self.types+"\n Description :"+self.description)
    if self.is_caught==True:
      print(self.name+"has already been caught")

pikachu=pokemon(25,"pikachu","electric","It has small electric sacs on both its cheeks. If threatened, it looses electric charges from the sacs.",True,3,"unova")
pikachu.speak()
pikachu.display_details()
