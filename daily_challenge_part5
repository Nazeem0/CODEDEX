  def calculate_score(elements):
  Element_Score=[]
	  # Write code below 💖
  for i in range(len(elements)):
	  bias=remove_min_max(elements[i][2])
	  Average_GOE=sum(bias)/7
	  Element_Score.append(elements[i][1]+(Average_GOE*0.1*elements[i][1]))
  TES=sum(Element_Score)
  return round(TES,1)
	      
def remove_min_max(scores):
	scores.remove(max(scores))
	scores.remove(min(scores))	  
	return scores
